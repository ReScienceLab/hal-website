---
import { SITE, absoluteUrl, ogImagePath } from '../data/site';

interface Props {
  title: string;
  description?: string;
  path?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  path = Astro.url.pathname,
  schema,
  noindex = false,
} = Astro.props;

const canonicalUrl = absoluteUrl(path);
const imageUrl = absoluteUrl(ogImagePath(path));
const extraSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${SITE.domain}/#organization`,
      name: SITE.name,
      url: SITE.domain,
      logo: absoluteUrl('/favicon.svg'),
      sameAs: [SITE.repoUrl],
    },
    {
      "@type": "WebSite",
      "@id": `${SITE.domain}/#website`,
      name: SITE.name,
      url: SITE.domain,
      description: SITE.description,
      publisher: { "@id": `${SITE.domain}/#organization` },
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${SITE.domain}/#software`,
      name: SITE.name,
      applicationCategory: "DeveloperApplication",
      operatingSystem: "CLI",
      url: SITE.domain,
      codeRepository: SITE.repoUrl,
      description: SITE.description,
      publisher: { "@id": `${SITE.domain}/#organization` },
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
      },
    },
    ...extraSchema,
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex" />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={imageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --bg-primary: #0a0a0c;
      --bg-surface: #111114;
      --bg-elevated: #1a1a1e;
      --text-primary: #f0f0f0;
      --text-secondary: #8a8f98;
      --accent: #dc2626;
      --accent-hover: #ef4444;
      --border-subtle: rgba(255,255,255,0.06);
      --border-strong: rgba(255,255,255,0.10);
      --font-sans: 'Geist', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --font-mono: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
      background: var(--bg-primary);
      color: var(--text-primary);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      min-height: 100vh;
      line-height: 1.55;
      font-feature-settings: 'liga' 1;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    ::selection {
      background: rgba(220, 38, 38, 0.3);
      color: var(--text-primary);
    }

    .page-container {
      width: min(1080px, 100% - 3rem);
      margin: 0 auto;
    }

    .simple-nav {
      position: sticky;
      top: 0;
      z-index: 40;
      backdrop-filter: blur(10px);
      background: rgba(10, 10, 12, 0.84);
      border-bottom: 1px solid var(--border-subtle);
    }

    .simple-nav__inner {
      min-height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .simple-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-family: var(--font-mono);
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: -0.02em;
      text-transform: lowercase;
    }

    .simple-brand__eye {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 10px rgba(220, 38, 38, 0.5);
      flex: 0 0 auto;
    }

    .simple-nav__links {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      font-size: 0.92rem;
      color: var(--text-secondary);
    }

    .simple-nav__links a:hover,
    .simple-footer a:hover {
      color: var(--text-primary);
    }

    .page-hero {
      padding: clamp(3rem, 6vw, 5rem) 0 2rem;
      border-bottom: 1px solid var(--border-subtle);
      background: radial-gradient(circle at top right, rgba(220, 38, 38, 0.1), transparent 40%);
    }

    .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.76rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-secondary);
      margin-bottom: 0.9rem;
    }

    .page-hero h1 {
      font-size: clamp(2rem, 4.8vw, 3.4rem);
      line-height: 1.06;
      letter-spacing: -0.04em;
      margin-bottom: 0.9rem;
      max-width: 20ch;
    }

    .page-hero p {
      color: var(--text-secondary);
      max-width: 70ch;
      font-size: 1.03rem;
    }

    .hero-meta {
      margin-top: 0.75rem;
      font-size: 0.92rem;
      color: var(--text-secondary);
    }

    .hero-meta a {
      color: var(--text-primary);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .btn-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .btn-primary,
    .btn-ghost {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.6rem;
      padding: 0.7rem 1.05rem;
      font-size: 0.92rem;
      font-weight: 500;
      transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }

    .btn-primary {
      background: var(--accent);
      border: 1px solid transparent;
      color: #fff;
    }

    .btn-primary:hover {
      background: var(--accent-hover);
    }

    .btn-ghost {
      border: 1px solid var(--border-strong);
      color: var(--text-primary);
      background: rgba(255, 255, 255, 0.02);
    }

    .btn-ghost:hover {
      border-color: rgba(255, 255, 255, 0.2);
      background: rgba(255, 255, 255, 0.05);
    }

    .page-section {
      padding: clamp(2.3rem, 5vw, 4.5rem) 0;
      border-top: 1px solid var(--border-subtle);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1rem;
    }

    .info-card {
      display: block;
      border: 1px solid var(--border-subtle);
      background: var(--bg-surface);
      border-radius: 0.9rem;
      padding: 1.15rem;
      transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
    }

    .info-card:hover {
      border-color: var(--border-strong);
      background: var(--bg-elevated);
      transform: translateY(-1px);
    }

    .info-card h3 {
      font-size: 1.1rem;
      letter-spacing: -0.02em;
      margin-bottom: 0.45rem;
    }

    .info-card p {
      color: var(--text-secondary);
      font-size: 0.96rem;
    }

    .kicker {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 0.55rem;
    }

    .section-head {
      margin-bottom: 1.4rem;
    }

    .section-head h2 {
      font-size: clamp(1.45rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
      margin-bottom: 0.45rem;
    }

    .section-head p {
      color: var(--text-secondary);
    }

    .section-head.center {
      text-align: center;
    }

    .prose {
      max-width: 72ch;
      color: var(--text-primary);
    }

    .prose > * + * {
      margin-top: 1rem;
    }

    .prose h2,
    .prose h3 {
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-top: 1.7rem;
    }

    .prose h2 {
      font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    }

    .prose p,
    .prose li {
      color: #d4d6dc;
    }

    .prose ul,
    .prose ol {
      padding-left: 1.25rem;
    }

    .prose li + li {
      margin-top: 0.4rem;
    }

    .prose table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border: 1px solid var(--border-subtle);
      border-radius: 0.7rem;
      background: var(--bg-surface);
      font-size: 0.95rem;
    }

    .prose th,
    .prose td {
      border: 1px solid var(--border-subtle);
      padding: 0.75rem 0.8rem;
      text-align: left;
      vertical-align: top;
    }

    .prose th {
      color: var(--text-primary);
      background: rgba(255, 255, 255, 0.04);
      font-weight: 600;
    }

    .prose code {
      font-family: var(--font-mono);
      font-size: 0.9em;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid var(--border-subtle);
      border-radius: 0.35rem;
      padding: 0.1rem 0.3rem;
    }

    .prose pre {
      background: #0c0c10;
      border: 1px solid var(--border-subtle);
      border-radius: 0.7rem;
      padding: 0.95rem 1rem;
      overflow-x: auto;
    }

    .prose pre code {
      background: transparent;
      border: 0;
      padding: 0;
      color: #f2f3f7;
      line-height: 1.65;
      font-size: 0.9rem;
    }

    .prose a {
      color: #ff8585;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .faq-list {
      display: grid;
      gap: 0.9rem;
      max-width: 76ch;
      margin: 0 auto;
    }

    .faq-item {
      border: 1px solid var(--border-subtle);
      background: var(--bg-surface);
      border-radius: 0.8rem;
      padding: 1rem 1.05rem;
    }

    .faq-item h3 {
      font-size: 1.05rem;
      margin-bottom: 0.45rem;
      letter-spacing: -0.02em;
    }

    .faq-item p {
      color: var(--text-secondary);
    }

    .simple-footer {
      border-top: 1px solid var(--border-subtle);
      padding: 1.35rem 0 2rem;
      color: var(--text-secondary);
      font-size: 0.86rem;
    }

    .simple-footer__inner {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem 1.6rem;
      align-items: center;
      justify-content: space-between;
    }

    .simple-footer__inner > div:last-child {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 0.8rem 1.1rem;
    }

    @media (max-width: 820px) {
      .page-container {
        width: min(1080px, 100% - 1.4rem);
      }

      .simple-nav__links {
        gap: 0.75rem;
        font-size: 0.84rem;
      }

      .page-hero h1 {
        max-width: 100%;
      }

      .simple-footer__inner {
        align-items: flex-start;
      }
    }

    @media (max-width: 640px) {
      .simple-nav__links {
        display: none;
      }

      .btn-row {
        width: 100%;
      }

      .btn-primary,
      .btn-ghost {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
