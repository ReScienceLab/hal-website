---
import { SITE, absoluteUrl, ogImagePath } from "../data/site";

interface Props {
  title: string;
  description?: string;
  path?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = SITE.description,
  path = "/",
  noindex = false,
  schema = [],
} = Astro.props;

const canonical = absoluteUrl(path);
const imageUrl = absoluteUrl(noindex ? "/og/home.svg" : ogImagePath(path));
const baseGraph: Array<Record<string, unknown>> = [
  {
    "@type": "Organization",
    "@id": `${SITE.domain}/#organization`,
    name: "ReScience Lab",
    url: "https://rescience.com",
  },
  {
    "@type": "WebSite",
    "@id": `${SITE.domain}/#website`,
    name: SITE.name,
    url: SITE.domain,
    description: SITE.description,
    publisher: { "@id": `${SITE.domain}/#organization` },
  },
  {
    "@type": "SoftwareApplication",
    "@id": `${SITE.domain}/#software`,
    name: SITE.name,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "macOS, Linux",
    url: SITE.repoUrl,
    sameAs: [SITE.repoUrl, SITE.rescienceUrl],
    description: SITE.description,
    softwareVersion: SITE.version,
    provider: { "@id": `${SITE.domain}/#organization` },
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      url: absoluteUrl("/pricing"),
      availability: "https://schema.org/InStock",
    },
  },
  {
    "@type": "WebPage",
    "@id": `${canonical}#webpage`,
    url: canonical,
    name: title,
    description,
    dateModified: "2026-05-04",
    isPartOf: { "@id": `${SITE.domain}/#website` },
  },
];
const extraSchemas = Array.isArray(schema) ? schema : [schema];
const jsonLd = JSON.stringify({ "@context": "https://schema.org", "@graph": [...baseGraph, ...extraSchemas.filter(Boolean)] }).replace(/</g, "\\u003c");
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={imageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="alternate icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
  {!noindex && <script is:inline type="application/ld+json" set:html={jsonLd} />}
  <style is:global>
    :root {
      --bg-primary: #0a0a0c;
      --bg-surface: #111114;
      --bg-elevated: #1a1a1e;
      --text-primary: #f0f0f0;
      --text-secondary: #8a8f98;
      --accent: #dc2626;
      --accent-hover: #ef4444;
      --success: #27a644;
      --border-subtle: rgba(255,255,255,0.06);
      --border-strong: rgba(255,255,255,0.10);
      --font-sans: 'Geist', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --font-mono: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      background: var(--bg-primary);
      color: var(--text-primary);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body { min-height: 100vh; line-height: 1.55; font-feature-settings: 'liga' 1; }
    a { color: inherit; text-decoration: none; }
    p a, .prose a { color: var(--text-primary); text-decoration: underline; text-underline-offset: 3px; }
    ::selection { background: rgba(220, 38, 38, 0.3); color: var(--text-primary); }

    .page-container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
    .simple-nav { position: sticky; top: 0; z-index: 100; background: rgba(10,10,12,.88); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-subtle); }
    .simple-nav__inner { min-height: 64px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
    .simple-brand { display: inline-flex; align-items: center; gap: 10px; color: var(--text-primary); font-family: var(--font-mono); font-size: 18px; font-weight: 500; }
    .simple-brand__eye { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 8px rgba(220,38,38,.5); }
    .simple-nav__links { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; justify-content: flex-end; }
    .simple-nav__links a { color: var(--text-secondary); font-size: 14px; font-weight: 500; }
    .simple-nav__links a:hover { color: var(--text-primary); }

    .page-hero { padding: 88px 0 56px; text-align: center; }
    .eyebrow { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 24px; color: var(--text-secondary); font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: .04em; text-transform: uppercase; }
    .eyebrow::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 6px rgba(220,38,38,.5); }
    .page-hero h1 { max-width: 820px; margin: 0 auto 18px; color: var(--text-primary); font-size: clamp(38px, 7vw, 64px); font-weight: 600; line-height: 1.05; letter-spacing: -1.8px; }
    .page-hero p { max-width: 680px; margin: 0 auto; color: var(--text-secondary); font-size: 18px; line-height: 1.6; letter-spacing: -.02em; }

    .page-section { padding: 72px 0; border-top: 1px solid var(--border-subtle); }
    .section-head { max-width: 680px; margin-bottom: 32px; }
    .section-head.center { margin-left: auto; margin-right: auto; text-align: center; }
    .section-head h2 { color: var(--text-primary); font-size: clamp(28px, 4vw, 42px); font-weight: 600; line-height: 1.1; letter-spacing: -1.2px; margin-bottom: 12px; }
    .section-head p { color: var(--text-secondary); font-size: 17px; line-height: 1.58; }

    .btn-row { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; justify-content: center; margin-top: 28px; }
    .btn-primary, .btn-ghost { display: inline-flex; align-items: center; justify-content: center; min-height: 46px; padding: 12px 22px; border-radius: 8px; font-size: 15px; font-weight: 500; transition: background .2s ease, border-color .2s ease, transform .2s ease; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-hover); transform: translateY(-1px); }
    .btn-ghost { background: rgba(255,255,255,.03); border: 1px solid var(--border-subtle); color: var(--text-primary); }
    .btn-ghost:hover { background: rgba(255,255,255,.06); border-color: var(--border-strong); }

    .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 18px; }
    .info-card { display: block; background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 24px; transition: background .2s ease, border-color .2s ease, transform .2s ease; }
    .info-card:hover { background: var(--bg-elevated); border-color: var(--border-strong); transform: translateY(-2px); }
    .info-card .kicker { color: var(--accent); font-family: var(--font-mono); font-size: 12px; margin-bottom: 12px; }
    .info-card h3 { color: var(--text-primary); font-size: 18px; line-height: 1.25; margin-bottom: 8px; }
    .info-card p { color: var(--text-secondary); font-size: 15px; line-height: 1.55; }

    .prose { max-width: 760px; margin: 0 auto; }
    .prose h2 { color: var(--text-primary); font-size: 30px; line-height: 1.15; letter-spacing: -0.8px; margin: 36px 0 12px; }
    .prose h3 { color: var(--text-primary); font-size: 20px; margin: 26px 0 8px; }
    .prose p, .prose li { color: var(--text-secondary); font-size: 16px; line-height: 1.68; }
    .prose p { margin-bottom: 16px; }
    .prose ul, .prose ol { margin: 0 0 20px 22px; }
    .prose li + li { margin-top: 8px; }
    code { font-family: var(--font-mono); background: rgba(255,255,255,.05); color: var(--text-primary); border-radius: 4px; padding: 2px 6px; }
    pre { overflow-x: auto; background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 20px; color: var(--text-secondary); font-family: var(--font-mono); font-size: 14px; line-height: 1.65; margin: 20px 0; }
    pre code { background: transparent; padding: 0; }

    .terminal-panel { background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 12px; overflow: hidden; max-width: 820px; margin: 28px auto; }
    .terminal-panel__bar { display: flex; align-items: center; gap: 8px; padding: 14px 18px; border-bottom: 1px solid var(--border-subtle); background: rgba(255,255,255,.02); color: var(--text-secondary); font-family: var(--font-mono); font-size: 12px; }
    .terminal-panel__bar span.dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); }
    .terminal-panel__body { padding: 22px; color: var(--text-secondary); font-family: var(--font-mono); font-size: 14px; line-height: 1.7; }
    .terminal-panel__body .prompt { color: var(--accent); }
    .terminal-panel__body .ok { color: var(--success); }

    .faq-list { display: grid; gap: 14px; max-width: 820px; margin: 0 auto; }
    .faq-item { background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 22px; }
    .faq-item h3 { color: var(--text-primary); font-size: 17px; margin-bottom: 8px; }
    .faq-item p { color: var(--text-secondary); font-size: 15px; line-height: 1.6; }

    .simple-footer { border-top: 1px solid var(--border-subtle); padding: 36px 0; color: var(--text-secondary); }
    .simple-footer__inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-size: 14px; }
    .simple-footer a { color: var(--text-secondary); margin-left: 18px; }
    .simple-footer a:hover { color: var(--text-primary); }

    @media (max-width: 720px) {
      .simple-nav__inner { align-items: flex-start; flex-direction: column; padding: 14px 0; }
      .simple-nav__links { justify-content: flex-start; gap: 14px; }
      .page-hero { padding-top: 64px; }
      .btn-row { align-items: stretch; flex-direction: column; }
      .btn-row a, .btn-row button { width: 100%; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
