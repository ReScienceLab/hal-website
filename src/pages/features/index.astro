---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { SITE } from "../../data/site";

const features = await getCollection("features");
---
<Layout title="Hal Features - PRD-Driven AI Coding Automation" description="Deep dives into Hal planning, fresh context, engine support, standards, archive, and auto pipeline features." path="/features">
  <SiteNav />
  <section class="page-hero">
    <div class="page-container">
      <p class="eyebrow">Features</p>
      <h1>Hal features for autonomous coding loops</h1>
      <p>Deep dives into the mechanics behind PRD-driven planning, fresh context, pluggable engines, standards, archive state, and auto pipeline behavior.</p>
    </div>
  </section>
  <section class="page-section">
    <div class="page-container">
      <div class="card-grid">
        {features.map((feature, index) => (
          <a class="info-card" href={`/features/${feature.id.replace(/\.md$/, "")}`}>
            <p class="kicker">{String(index + 1).padStart(2, "0")} //</p>
            <h3>{feature.data.title.replace(" - Hal Feature", "")}</h3>
            <p>{feature.data.description}</p>
          </a>
        ))}
      </div>
      <div class="btn-row">
        <a class="btn-primary" href="/docs">Read docs</a>
        <a class="btn-ghost" href={SITE.repoUrl} target="_blank" rel="noreferrer">View source</a>
      </div>
    </div>
  </section>
  <SiteFooter />
</Layout>
