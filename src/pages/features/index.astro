---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { featureSlug, sortFeaturesByOrder } from "../../data/features";
import { SITE } from "../../data/site";

const features = sortFeaturesByOrder(await getCollection("features"));
---
<Layout title="Hal Features - Reviewable AI Coding Loops" description="Explore Hal features for PRD planning, fresh story context, pluggable engines, project standards, archived state, and deterministic loop execution." path="/features">
  <SiteNav />
  <section class="page-hero">
    <div class="page-container">
      <p class="eyebrow">Features</p>
      <h1>Features for reviewable AI coding loops</h1>
      <p>Hal gives coding agents a workflow: plan the requirement, bound the context, inject local standards, run implementation, and preserve the trail for human review.</p>
    </div>
  </section>
  <section class="page-section">
    <div class="page-container">
      <div class="card-grid">
        {features.map((feature, index) => (
          <a class="info-card" href={`/features/${featureSlug(feature)}/`}>
            <p class="kicker">{String(index + 1).padStart(2, "0")} //</p>
            <h3>{feature.data.h1}</h3>
            <p>{feature.data.description}</p>
          </a>
        ))}
      </div>
      <div class="btn-row">
        <a class="btn-primary" href="/docs/first-loop/">Run the first loop</a>
        <a class="btn-ghost" href={SITE.repoUrl} target="_blank" rel="noreferrer">Inspect source</a>
      </div>
    </div>
  </section>
  <SiteFooter />
</Layout>
