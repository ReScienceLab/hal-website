---
import { getCollection } from "astro:content";
import ContentPage from "../../components/ContentPage.astro";
import { featureSlug, sortFeaturesByOrder } from "../../data/features";

export async function getStaticPaths() {
  const entries = sortFeaturesByOrder(await getCollection("features"));
  return entries.map((entry) => ({
    params: { slug: featureSlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const allFeatures = sortFeaturesByOrder(await getCollection("features"));
const entrySlug = featureSlug(entry);
const featureIndex = allFeatures.findIndex((f) => featureSlug(f) === entrySlug) + 1;
const path = `/features/${entrySlug}`;
---

<ContentPage
  entry={entry}
  path={path}
  eyebrow={`Feature ${String(featureIndex).padStart(2, "0")}`}
/>
