---
import { getCollection } from "astro:content";
import ContentPage from "../../components/ContentPage.astro";

export async function getStaticPaths() {
  const entries = await getCollection("features");
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const allFeatures = await getCollection("features");
const entrySlug = entry.id.replace(/\.md$/, "");
const featureIndex = allFeatures.findIndex((f) => f.id.replace(/\.md$/, "") === entrySlug) + 1;
const path = `/features/${entrySlug}`;
---

<ContentPage
  entry={entry}
  path={path}
  eyebrow={`Feature ${String(featureIndex).padStart(2, "0")}`}
/>
