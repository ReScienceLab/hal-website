---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { SITE } from "../data/site";

const faqs = [
  { question: "Is Hal currently a hosted paid product?", answer: "No. This site presents Hal as an open-source CLI. It does not describe a hosted Hal Cloud plan, paid tier, seat price, usage quota, or SLA today." },
  { question: "Do I still pay for AI model usage?", answer: "Hal can use external AI coding engines. Any costs or limits from those tools are separate from this website and depend on the engine you configure." },
  { question: "What should I verify before adopting Hal?", answer: `Inspect the source, license, releases, install path, and docs in the GitHub repository at ${SITE.repoUrl}.` },
];
const lastUpdated = "2026-05-09";
const schema = [
  {
    "@type": "Offer",
    "@id": `${SITE.domain}/pricing/#offer`,
    price: "0",
    priceCurrency: "USD",
    url: `${SITE.domain}/pricing`,
    availability: "https://schema.org/InStock",
    itemOffered: { "@type": "SoftwareApplication", name: SITE.name, url: SITE.repoUrl },
  },
  {
    "@type": "FAQPage",
    "@id": `${SITE.domain}/pricing/#faq`,
    mainEntity: faqs.map((faq) => ({ "@type": "Question", name: faq.question, acceptedAnswer: { "@type": "Answer", text: faq.answer } })),
  },
];
---
<Layout title="Hal Pricing - Free Open Source CLI" description="Hal is a free, open-source CLI on this website. Review the install path, source repository, external engine costs, and current product caveats." path="/pricing" schema={schema}>
  <SiteNav />
  <section class="page-hero">
    <div class="page-container">
      <p class="eyebrow">Pricing</p>
      <h1>Hal pricing</h1>
      <p>Hal is currently presented on this website as a free, open-source CLI. There is no hosted Hal Cloud plan, paid tier, seat price, usage quota, or SLA described here today.</p>
      <p class="hero-meta">Last updated: {lastUpdated} · <a href="/pricing.md">Read machine-readable pricing</a></p>
      <div class="btn-row">
        <a class="btn-primary" href={SITE.repoUrl} target="_blank" rel="noreferrer">Inspect source and license</a>
        <a class="btn-ghost" href="/docs/first-loop/">Run the first loop</a>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="page-container">
      <div class="card-grid">
        <article class="info-card"><p class="kicker">Current status</p><h3>Free open-source CLI</h3><p>Install Hal as a command-line tool and inspect the repository before adopting it in a project.</p></article>
        <article class="info-card"><p class="kicker">Separate costs</p><h3>Bring your own engine</h3><p>Hal can work with external coding agents. Any model, IDE, or API cost belongs to the provider you configure.</p></article>
        <article class="info-card"><p class="kicker">No invented tiers</p><h3>No hosted plan described</h3><p>This page does not claim hosted collaboration, seat pricing, usage quotas, SLAs, or commercial tiers that are not documented here.</p></article>
        <article class="info-card"><p class="kicker">AI-readable</p><h3>Markdown pricing file</h3><p>Use <a href="/pricing.md">/pricing.md</a> for a parseable summary of pricing status, external costs, and adoption caveats.</p></article>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="page-container">
      <div class="section-head center"><h2>FAQ</h2><p>Pricing answers without inventing plans, tiers, or limits.</p></div>
      <div class="faq-list">{faqs.map((faq) => <article class="faq-item"><h3>{faq.question}</h3><p>{faq.answer}</p></article>)}</div>
    </div>
  </section>
  <SiteFooter />
</Layout>
