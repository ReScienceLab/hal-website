---
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { SITE } from "../../data/site";

const faqs = [
  { question: "What do I need before running Hal?", answer: "You need a repository, a clear product requirement or PRD, and access to a supported AI coding engine such as Codex, Claude Code, or Pi." },
  { question: "What should my first loop be?", answer: "Start with a small, low-risk requirement that has clear acceptance criteria and can be reviewed in one sitting." },
  { question: "Does Hal replace code review?", answer: "No. Hal is designed to leave reviewable state, commits, reports, and archives so a developer can inspect the work before merging." },
  { question: "Where is the source code?", answer: `The Hal source is available on GitHub at ${SITE.repoUrl}.` },
];
const schema = [{
  "@type": "FAQPage",
  "@id": `${SITE.domain}/docs/#faq`,
  mainEntity: faqs.map((faq) => ({ "@type": "Question", name: faq.question, acceptedAnswer: { "@type": "Answer", text: faq.answer } })),
}];
---
<Layout title="Hal Docs - Run a Reviewable AI Coding Loop" description="Install Hal, initialize a repo, plan a PRD, validate stories, run the loop, and inspect the result before merging." path="/docs" schema={schema}>
  <SiteNav />
  <section class="page-hero">
    <div class="page-container">
      <p class="eyebrow">Docs</p>
      <h1>Hal docs for reviewable coding loops</h1>
      <p>Install Hal, initialize the repo workflow, turn requirements into stories, run a bounded agent loop, and inspect the result before merging.</p>
      <div class="btn-row">
        <a class="btn-primary" href="/docs/first-loop/">Run the first loop</a>
        <a class="btn-ghost" href={SITE.repoUrl} target="_blank" rel="noreferrer">Read GitHub README</a>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="page-container prose">
      <h2>Install</h2>
      <p>Use the current website install command, then open the GitHub README if you need repository-specific setup details before running it in a project.</p>
      <pre><code>{SITE.installCommand}</code></pre>
      <p><a href="/docs/install/">Read the install guide</a> for verification steps, engine prerequisites, and a safe repository setup.</p>

      <h2>First loop</h2>
      <p>Your first Hal loop should be boring on purpose. Pick a bounded change with clear acceptance criteria so you can inspect the plan, the changed files, and the final state in one sitting.</p>
      <pre><code>{`hal init
hal plan "add a small settings page with one saved preference"
hal convert
hal validate
hal run`}</code></pre>

      <h2>What each command does</h2>
      <ul>
        <li><code>hal init</code> creates the local workflow structure for a repo.</li>
        <li><code>hal plan</code> turns product intent into a PRD or structured requirements before the agent touches code.</li>
        <li><code>hal convert</code> turns markdown requirements into runtime state.</li>
        <li><code>hal validate</code> checks that stories are specific enough for the loop.</li>
        <li><code>hal run</code> executes implementation iterations with the configured agent engine.</li>
      </ul>

      <h2>Review checklist</h2>
      <p>Before merging agent output, inspect the changed files, commits, reports, tests, and unresolved acceptance criteria. Hal structures the loop; the developer still owns acceptance.</p>
      <p><a href="/docs/review-before-merge/">Use the review-before-merge checklist</a> before accepting any generated code.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="page-container">
      <div class="section-head center"><h2>Detailed docs</h2><p>Move from installation to a bounded first loop and a human-owned merge decision.</p></div>
      <div class="card-grid">
        <a class="info-card" href="/docs/install/"><p class="kicker">Setup</p><h3>Install Hal CLI</h3><p>Install the command, verify it works, and check engine prerequisites.</p></a>
        <a class="info-card" href="/docs/first-loop/"><p class="kicker">Quickstart</p><h3>Run your first Hal loop</h3><p>Plan, convert, validate, run, and inspect a small task.</p></a>
        <a class="info-card" href="/docs/review-before-merge/"><p class="kicker">Review</p><h3>Review before merge</h3><p>Use a checklist for diffs, commits, reports, tests, and acceptance criteria.</p></a>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="page-container">
      <div class="section-head center"><h2>FAQ</h2><p>Short answers before you put an agent loop in motion.</p></div>
      <div class="faq-list">{faqs.map((faq) => <article class="faq-item"><h3>{faq.question}</h3><p>{faq.answer}</p></article>)}</div>
    </div>
  </section>
  <SiteFooter />
</Layout>
