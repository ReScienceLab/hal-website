---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import SiteNav from "./SiteNav.astro";
import SiteFooter from "./SiteFooter.astro";
import ToolRunner from "./ToolRunner.astro";
import { sortToolsByOrder, toolSlug } from "../data/tools";
import { SITE, absoluteUrl } from "../data/site";

type ToolEntryLike = CollectionEntry<"tools">;

interface Props {
  entry: ToolEntryLike;
  path: string;
}

const { entry, path } = Astro.props;
const slug = toolSlug(entry);
const { Content } = await render(entry);
const faqs = entry.data.faqs ?? [];
const allTools = sortToolsByOrder(await getCollection("tools"));
const related = (entry.data.related?.length
  ? entry.data.related.map((relatedSlug) => allTools.find((tool) => toolSlug(tool) === relatedSlug)).filter(Boolean)
  : allTools.filter((tool) => toolSlug(tool) !== slug).slice(0, 3)) as ToolEntryLike[];

function formatDisplayDate(value: string) {
  const [year, month, day] = value.split("-").map(Number);
  return new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(
    new Date(Date.UTC(year, month - 1, day))
  );
}

const displayUpdatedAt = formatDisplayDate(entry.data.updatedAt);
const canonicalUrl = absoluteUrl(path);
const schema = [
  {
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
      { "@type": "ListItem", position: 2, name: "Tools", item: absoluteUrl("/tools") },
      { "@type": "ListItem", position: 3, name: entry.data.h1, item: canonicalUrl },
    ],
  },
  {
    "@type": "WebApplication",
    "@id": `${canonicalUrl}#tool`,
    name: entry.data.h1,
    url: canonicalUrl,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Web",
    description: entry.data.description,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    publisher: { "@id": `${SITE.domain}/#organization` },
  },
  ...(faqs.length > 0
    ? [{
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: { "@type": "Answer", text: faq.answer },
      })),
    }]
    : []),
];
---

<Layout title={entry.data.title} description={entry.data.description} path={path} schema={schema} noindex={entry.data.noindex ?? false}>
  <SiteNav />
  <section class="page-hero">
    <div class="page-container">
      <p class="eyebrow">Free developer tool</p>
      <h1>{entry.data.h1}</h1>
      <p>{entry.data.summary ?? entry.data.description}</p>
      <p class="hero-meta">Last updated: {displayUpdatedAt} · Reviewed by {entry.data.reviewedBy}</p>
      <div class="btn-row">
        <a class="btn-primary" href="#tool">Run the tool</a>
        <a class="btn-ghost" href="/tools/">See all tools</a>
      </div>
    </div>
  </section>

  <section class="page-section" id="tool">
    <div class="page-container">
      <ToolRunner slug={slug} />
    </div>
  </section>

  <section class="page-section">
    <div class="page-container prose">
      <Content />
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="page-section" id="faq">
      <div class="page-container">
        <div class="section-head center">
          <h2>FAQ</h2>
          <p>Short answers before you hand the output to an agent workflow.</p>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => <article class="faq-item"><h3>{faq.question}</h3><p>{faq.answer}</p></article>)}
        </div>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section class="page-section">
      <div class="page-container">
        <div class="section-head center">
          <h2>Related free tools</h2>
          <p>Prepare better PRDs, stories, and standards before an agent touches the repo.</p>
        </div>
        <div class="card-grid">
          {related.map((tool) => (
            <a class="info-card" href={`/tools/${toolSlug(tool)}/`}>
              <p class="kicker">{tool.data.category}</p>
              <h3>{tool.data.h1}</h3>
              <p>{tool.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="page-section">
    <div class="page-container">
      <div class="info-card">
        <p class="kicker">Next step</p>
        <h2>Use the output in a Hal loop</h2>
        <p>Hal is a terminal-first CLI for PRD-native coding loops. Use the generated markdown as planning input, keep the work bounded, and review agent output before merging.</p>
        <div class="btn-row">
          <a class="btn-primary" href="/docs/">Read Hal docs</a>
          <a class="btn-ghost" href={SITE.repoUrl} target="_blank" rel="noreferrer">View GitHub</a>
        </div>
      </div>
    </div>
  </section>
  <SiteFooter />
</Layout>
