---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import SiteNav from "./SiteNav.astro";
import SiteFooter from "./SiteFooter.astro";
import { sortFeaturesByOrder } from "../data/features";
import { SITE, absoluteUrl } from "../data/site";

interface PageFaq {
  question: string;
  answer: string;
}

interface Props {
  entry: {
    id: string;
    collection: string;
    data: {
      title: string;
      description: string;
      h1: string;
      pageType: "feature" | "docs" | "faq" | "glossary" | "tool";
      updatedAt: string;
      reviewedBy: string;
      summary?: string;
      faqs?: PageFaq[];
      related?: string[];
      noindex?: boolean;
    };
  };
  path: string;
  eyebrow?: string;
}

const { entry, path, eyebrow } = Astro.props;
const { Content } = await render(entry);

const collection = entry.collection;
const faqs = entry.data.faqs ?? [];
const collectionLabels: Record<string, string> = {
  features: "features",
  docs: "docs",
  faq: "FAQ",
  glossary: "glossary entries",
};
const breadcrumbLabels: Record<string, string> = {
  features: "Features",
  docs: "Docs",
  faq: "FAQ",
  glossary: "Glossary",
};
const collectionPath = (item: Pick<Props["entry"], "id" | "collection">) => {
  const slug = item.id.replace(/\.md$/, "");
  return `/${item.collection}/${slug}/`;
};
const relatedCollections = ["features", "docs", "faq", "glossary", "tools"] as const;
type RelatedCollection = typeof relatedCollections[number];
const isRelatedCollection = (value: string): value is RelatedCollection =>
  relatedCollections.includes(value as RelatedCollection);
const entrySlug = (item: Pick<Props["entry"], "id">) => item.id.replace(/\.md$/, "");
const relatedTarget = (value: string, fallbackCollection: string) => {
  const path = value.split(/[?#]/)[0].replace(/^\/+|\/+$/g, "");
  const segments = path.split("/").filter(Boolean);

  if (segments.length === 0) {
    return null;
  }

  if (segments.length > 1 && isRelatedCollection(segments[0])) {
    return {
      collection: segments[0],
      slug: segments.slice(1).join("/"),
    };
  }

  return isRelatedCollection(fallbackCollection)
    ? { collection: fallbackCollection, slug: segments.join("/") }
    : null;
};
let related: Props["entry"][] = [];

if (entry.data.related && entry.data.related.length > 0) {
  const targetCollections = new Map<RelatedCollection, Awaited<ReturnType<typeof getCollection>>>();

  await Promise.all(
    entry.data.related.map(async (value) => {
      const target = relatedTarget(value, collection);
      if (target && !targetCollections.has(target.collection)) {
        targetCollections.set(target.collection, await getCollection(target.collection));
      }
    })
  );

  related = entry.data.related
    .map((value: string) => {
      const target = relatedTarget(value, collection);
      if (!target) {
        return null;
      }

      return targetCollections.get(target.collection)?.find((e) => entrySlug(e) === target.slug);
    })
    .filter(Boolean)
    .slice(0, 3) as Props["entry"][];
} else if (collection === "features") {
  const all = sortFeaturesByOrder(await getCollection("features"));
  related = all.filter((e) => e.id !== entry.id).slice(0, 3) as Props["entry"][];
}

function formatDisplayDate(value: string) {
  const [year, month, day] = value.split("-").map(Number);
  return new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(
    new Date(Date.UTC(year, month - 1, day))
  );
}

const displayUpdatedAt = formatDisplayDate(entry.data.updatedAt);
const canonicalUrl = absoluteUrl(path);
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
    { "@type": "ListItem", position: 2, name: breadcrumbLabels[collection] ?? "Pages", item: absoluteUrl(`/${collection}`) },
    { "@type": "ListItem", position: 3, name: entry.data.h1, item: canonicalUrl },
  ],
};
const articleSchema = {
  "@type": entry.data.pageType === "faq" ? "Article" : "TechArticle",
  "@id": `${canonicalUrl}#article`,
  headline: entry.data.h1,
  description: entry.data.description,
  datePublished: entry.data.updatedAt,
  dateModified: entry.data.updatedAt,
  author: { "@type": "Organization", name: entry.data.reviewedBy },
  reviewedBy: { "@type": "Organization", name: entry.data.reviewedBy },
  publisher: { "@id": `${SITE.domain}/#organization` },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  about: { "@id": `${SITE.domain}/#software` },
};
const faqSchema = faqs.length > 0
  ? {
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: { "@type": "Answer", text: faq.answer },
      })),
    }
  : null;
const definedTermSchema = entry.data.pageType === "glossary"
  ? {
      "@type": "DefinedTerm",
      "@id": `${canonicalUrl}#defined-term`,
      name: entry.data.h1,
      description: entry.data.summary ?? entry.data.description,
      url: canonicalUrl,
      inDefinedTermSet: absoluteUrl("/glossary"),
    }
  : null;
const schema = [breadcrumbSchema, articleSchema, ...(definedTermSchema ? [definedTermSchema] : []), ...(faqSchema ? [faqSchema] : [])];
---

<Layout title={entry.data.title} description={entry.data.description} path={path} schema={schema} noindex={entry.data.noindex ?? false}>
  <SiteNav />
  <section class="page-hero">
    <div class="page-container">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{entry.data.h1}</h1>
      <p>{entry.data.description}</p>
      <p class="hero-meta">Last updated: {displayUpdatedAt} · Reviewed by {entry.data.reviewedBy}</p>
      <div class="btn-row">
        <a class="btn-primary" href="/docs/first-loop/">Run the first loop</a>
        <a class="btn-ghost" href={SITE.repoUrl} target="_blank" rel="noreferrer">Inspect source</a>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="page-container prose">
      {entry.data.summary && (
        <div class="info-card">
          <p class="kicker">Why it matters</p>
          <p>{entry.data.summary}</p>
        </div>
      )}
      <Content />
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="page-section" id="faq">
      <div class="page-container">
        <div class="section-head center">
          <h2>FAQ</h2>
          <p>Short answers before you put this into an agent workflow.</p>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => <article class="faq-item"><h3>{faq.question}</h3><p>{faq.answer}</p></article>)}
        </div>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section class="page-section">
      <div class="page-container">
        <div class="section-head center">
          <h2>Related {collectionLabels[collection] ?? "pages"}</h2>
          <p>Keep exploring the pieces of a reviewable coding loop.</p>
        </div>
        <div class="card-grid">
          {related.map((item) => (
            <a class="info-card" href={collectionPath(item)}>
              <h3>{item.data.h1}</h3>
              <p>{item.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  <SiteFooter />
</Layout>
