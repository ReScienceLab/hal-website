---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import SiteNav from "./SiteNav.astro";
import SiteFooter from "./SiteFooter.astro";
import { featureSlug, sortFeaturesByOrder } from "../data/features";
import { SITE, absoluteUrl } from "../data/site";

interface PageFaq {
  question: string;
  answer: string;
}

interface Props {
  entry: {
    id: string;
    collection: string;
    data: {
      title: string;
      description: string;
      h1: string;
      summary?: string;
      faqs?: PageFaq[];
      related?: string[];
      noindex?: boolean;
    };
  };
  path: string;
  eyebrow?: string;
}

const { entry, path, eyebrow } = Astro.props;
const { Content } = await render(entry);

const collection = entry.collection;
const faqs = entry.data.faqs ?? [];
let related: Props["entry"][] = [];

if (entry.data.related && entry.data.related.length > 0) {
  const all = await getCollection(collection);
  related = entry.data.related
    .map((slug: string) => all.find((e) => e.id.replace(/\.md$/, "") === slug))
    .filter(Boolean)
    .slice(0, 3) as Props["entry"][];
} else if (collection === "features") {
  const all = sortFeaturesByOrder(await getCollection("features"));
  related = all.filter((e) => e.id !== entry.id).slice(0, 3) as Props["entry"][];
}

const schema = faqs.length > 0
  ? [{
      "@type": "FAQPage",
      "@id": `${absoluteUrl(path)}#faq`,
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: { "@type": "Answer", text: faq.answer },
      })),
    }]
  : [];
---

<Layout title={entry.data.title} description={entry.data.description} path={path} schema={schema} noindex={entry.data.noindex ?? false}>
  <SiteNav />
  <section class="page-hero">
    <div class="page-container">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{entry.data.h1}</h1>
      <p>{entry.data.description}</p>
      <div class="btn-row">
        <a class="btn-primary" href="/docs">Run the first loop</a>
        <a class="btn-ghost" href={SITE.repoUrl} target="_blank" rel="noreferrer">Inspect source</a>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="page-container prose">
      {entry.data.summary && (
        <div class="info-card">
          <p class="kicker">Why it matters</p>
          <p>{entry.data.summary}</p>
        </div>
      )}
      <Content />
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="page-section" id="faq">
      <div class="page-container">
        <div class="section-head center">
          <h2>FAQ</h2>
          <p>Short answers before you put this into an agent workflow.</p>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => <article class="faq-item"><h3>{faq.question}</h3><p>{faq.answer}</p></article>)}
        </div>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section class="page-section">
      <div class="page-container">
        <div class="section-head center">
          <h2>Related features</h2>
          <p>Keep exploring the pieces of a reviewable coding loop.</p>
        </div>
        <div class="card-grid">
          {related.map((item) => (
            <a class="info-card" href={`/features/${featureSlug(item)}`}>
              <h3>{item.data.title.replace(" - Hal Feature", "")}</h3>
              <p>{item.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  <SiteFooter />
</Layout>
